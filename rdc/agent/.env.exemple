# RDC Agent — Configuração
# ── Segurança & Acesso ───────────────────────────────────────────────────
AGENT_PASSWORD=
# Chave secreta JWT (gerada automaticamente se não definida)
# SECRET_KEY=chave_super_secreta_aqui

# ── Servidor ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8765
DEBUG=false

# ── Tokens de Sessão ─────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Antigravity (AI Agent) ───────────────────────────────────────────────
# Modelo da IA (padrão do litellm: openai/..., gemini/..., anthropic/...)
AI_MODEL='model'
# Chave da API correspondente ao modelo
AI_API_KEY='api-key'

# ── Preview Proxy ────────────────────────────────────────────────────────
SCAN_PORT_RANGE_START=3000
SCAN_PORT_RANGE_END=9999

# ── Limites de Arquivo ───────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
MAX_UPLOAD_SIZE_MB=100
