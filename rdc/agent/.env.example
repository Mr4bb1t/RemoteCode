# RDC Agent — Configuração
# Copie este arquivo para .env e ajuste os valores

# Senha de acesso ao agente (OBRIGATÓRIO ALTERAR)
AGENT_PASSWORD=minha_senha_segura

# Chave secreta JWT (gerada automaticamente se não definida)
# SECRET_KEY=chave_super_secreta_aqui

# Servidor
HOST=0.0.0.0
PORT=8765
DEBUG=false

# Tokens
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Antigravity CLI (ajuste para o caminho real do executável)
ANTIGRAVITY_COMMAND=antigravity

# Scan de portas para preview
SCAN_PORT_RANGE_START=3000
SCAN_PORT_RANGE_END=9999

# Limites de arquivo
MAX_FILE_SIZE_MB=50
MAX_UPLOAD_SIZE_MB=100
