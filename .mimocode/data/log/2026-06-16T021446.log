ppercase;\n219:             letter-spacing: 2px;\n220:             margin-bottom: 4px;\n221:         }\n222: \n223:         .info-card .value {\n224:             font-family: 'Orbitron', sans-serif;\n225:             font-size: 1rem;\n226:             font-weight: 700;\n227:             color: #fff;\n228:         }\n229: \n230:         .download-section {\n231:             background: var(--panel);\n232:             border: 1px solid var(--border-glow);\n233:             border-radius: 12px;\n234:             padding: 24px 20px;\n235:             margin-bottom: 24px;\n236:             backdrop-filter: blur(10px);\n237:         }\n238: \n239:         .section-header {\n240:             display: flex;\n241:             align-items: center;\n242:             gap: 10px;\n243:             margin-bottom: 20px;\n244:             padding-bottom: 12px;\n245:             border-bottom: 1px solid rgba(0, 240, 255, 0.1);\n246:         }\n247: \n248:         .section-header .hex-icon {\n249:             width: 36px;\n250:             height: 36px;\n251:             background: linear-gradient(135deg, var(--cyan), var(--purple));\n252:             clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);\n253:             display: flex;\n254:             align-items: center;\n255:             justify-content: center;\n256:             font-size: 0.9rem;\n257:         }\n258: \n259:         .section-header h2 {\n260:             font-family: 'Orbitron', sans-serif;\n261:             font-size: 0.85rem;\n262:             font-weight: 700;\n263:             color: var(--cyan);\n264:             letter-spacing: 2px;\n265:             text-transform: uppercase;\n266:         }\n267: \n268:         .file-list { list-style: none; }\n269: \n270:         .file-item {\n271:             background: rgba(0, 240, 255, 0.03);\n272:             border: 1px solid rgba(0, 240, 255, 0.08);\n273:             border-radius: 10px;\n274:             padding: 14px 16px;\n275:             margin-bottom: 10px;\n276:             display: flex;\n277:             align-items: center;\n278:             justify-content: space-between;\n279:             transition: all 0.3s;\n280:             position: relative;\n281:             overflow: hidden;\n282:         }\n283: \n284:         .file-item::before {\n285:             content: '';\n286:             position: absolute;\n287:             left: 0;\n288:             top: 0;\n289:             bottom: 0;\n290:             width: 3px;\n291:             background: linear-gradient(180deg, var(--cyan), var(--magenta));\n292:             opacity: 0;\n293:             transition: opacity 0.3s;\n294:         }\n295: \n296:         .file-item:hover {\n297:             border-color: var(--cyan);\n298:             background: rgba(0, 240, 255, 0.06);\n299:             transform: translateX(4px);\n300:         }\n301: \n302:         .file-item:hover::before { opacity: 1; }\n303: \n304:         .file-info {\n305:             display: flex;\n306:             align-items: center;\n307:             gap: 12px;\n308:             min-width: 0;\n309:             flex: 1;\n310:         }\n311: \n312:         .file-icon-wrapper {\n313:             width: 38px;\n314:             height: 38px;\n315:             background: linear-gradient(135deg, rgba(0,240,255,0.15), rgba(176,0,255,0.15));\n316:             border-radius: 8px;\n317:             display: flex;\n318:             align-items: center;\n319:             justify-content: center;\n320:             font-size: 1.1rem;\n321:             flex-shrink: 0;\n322:             border: 1px solid rgba(0, 240, 255, 0.2);\n323:         }\n324: \n325:         .file-details { min-width: 0; }\n326: \n327:         .file-name {\n328:             font-family: 'Share Tech Mono', monospace;\n329:             font-size: 0.8rem;\n330:             color: #e0e0e8;\n331:             white-space: nowrap;\n332:             overflow: hidden;\n333:             text-overflow: ellipsis;\n334:         }\n335: \n336:         .file-meta {\n337:             font-size: 0.65rem;\n338:             color: rgba(0, 240, 255, 0.4);\n339:             margin-top: 2px;\n340:             font-family: 'Share Tech Mono', monospace;\n341:         }\n342: \n343:         .download-btn {\n344:             background: linear-gradient(135deg, var(--cyan), var(--purple));\n345:             color: #000;\n346:             border: none;\n347:             padding: 8px 18px;\n348:             border-radius: 6px;\n349:             cursor: pointer;\n350:             text-decoration: none;\n351:             font-family: 'Orbitron', sans-serif;\n352:             font-size: 0.65rem;\n353:             font-weight: 700;\n354:             letter-spacing: 1px;\n355:             text-transform: uppercase;\n356:             transition: all 0.3s;\n357:             flex-shrink: 0;\n358:             margin-left: 12px;\n359:         }\n360: \n361:         .download-btn:hover {\n362:             box-shadow: 0 0 20px rgba(0, 240, 255, 0.5), 0 0 40px rgba(176, 0, 255, 0.3);\n363:             transform: scale(1.05);\n364:         }\n365: \n366:         .download-btn:active {\n367:             transform: scale(0.97);\n368:         }\n369: \n370:         .empty-state {\n371:             text-align: center;\n372:             padding: 40px 20px;\n373:         }\n374: \n375:         .empty-state .empty-icon {\n376:             font-size: 2.5rem;\n377:             margin-bottom: 12px;\n378:             animation: float 3s ease-in-out infinite;\n379:         }\n380: \n381:         .empty-state p {\n382:             font-family: 'Share Tech Mono', monospace;\n383:             font-size: 0.8rem;\n384:             color: rgba(200, 200, 212, 0.4);\n385:             letter-spacing: 1px;\n386:         }\n387: \n388:         .features {\n389:             display: grid;\n390:             grid-template-columns: 1fr;\n391:             gap: 10px;\n392:             margin-bottom: 24px;\n393:         }\n394: \n395:         .fea