       inset: 0;\n46:             background:\n47:                 linear-gradient(180deg, rgba(10,10,18,0.3) 0%, transparent 30%, transparent 70%, rgba(10,10,18,0.6) 100%),\n48:                 repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,240,255,0.015) 2px, rgba(0,240,255,0.015) 4px);\n49:             z-index: 1;\n50:             pointer-events: none;\n51:             animation: scanlines 8s linear infinite;\n52:         }\n53: \n54:         @keyframes scanlines {\n55:             0% { background-position: 0 0; }\n56:             100% { background-position: 0 100px; }\n57:         }\n58: \n59:         @keyframes flicker {\n60:             0%, 95%, 100% { opacity: 1; }\n61:             96% { opacity: 0.8; }\n62:             97% { opacity: 1; }\n63:             98% { opacity: 0.6; }\n64:         }\n65: \n66:         @keyframes glitchShift {\n67:             0%, 100% { transform: translate(0); }\n68:             20% { transform: translate(-2px, 1px); }\n69:             40% { transform: translate(2px, -1px); }\n70:             60% { transform: translate(-1px, -1px); }\n71:             80% { transform: translate(1px, 2px); }\n72:         }\n73: \n74:         @keyframes borderPulse {\n75:             0%, 100% { border-color: rgba(0, 240, 255, 0.2); box-shadow: 0 0 10px rgba(0,240,255,0.05); }\n76:             50% { border-color: rgba(0, 240, 255, 0.5); box-shadow: 0 0 20px rgba(0,240,255,0.15); }\n77:         }\n78: \n79:         @keyframes neonPulse {\n80:             0%, 100% { text-shadow: 0 0 10px var(--cyan), 0 0 40px rgba(0,240,255,0.3); }\n81:             50% { text-shadow: 0 0 20px var(--cyan), 0 0 60px rgba(0,240,255,0.5); }\n82:         }\n83: \n84:         @keyframes float {\n85:             0%, 100% { transform: translateY(0); }\n86:             50% { transform: translateY(-6px); }\n87:         }\n88: \n89:         .main-wrapper {\n90:             position: relative;\n91:             z-index: 2;\n92:             min-height: 100vh;\n93:             min-height: 100dvh;\n94:             display: flex;\n95:             flex-direction: column;\n96:             padding: 20px;\n97:         }\n98: \n99:         .top-bar {\n100:             display: flex;\n101:             justify-content: space-between;\n102:             align-items: center;\n103:             padding: 12px 16px;\n104:             background: var(--panel);\n105:             border: 1px solid var(--border-glow);\n106:             border-radius: 8px;\n107:             margin-bottom: 24px;\n108:             backdrop-filter: blur(10px);\n109:         }\n110: \n111:         .top-bar .brand {\n112:             font-family: 'Orbitron', sans-serif;\n113:             font-size: 0.75rem;\n114:             font-weight: 900;\n115:             color: var(--cyan);\n116:             letter-spacing: 4px;\n117:             text-transform: uppercase;\n118:         }\n119: \n120:         .top-bar .status {\n121:             font-family: 'Share Tech Mono', monospace;\n122:             font-size: 0.65rem;\n123:             color: rgba(0, 240, 255, 0.6);\n124:         }\n125: \n126:         .status-dot {\n127:             display: inline-block;\n128:             width: 6px;\n129:             height: 6px;\n130:             background: #00ff88;\n131:             border-radius: 50%;\n132:             margin-right: 6px;\n133:             animation: neonPulse 2s ease-in-out infinite;\n134:             box-shadow: 0 0 6px #00ff88;\n135:         }\n136: \n137:         .hero {\n138:             text-align: center;\n139:             padding: 30px 10px;\n140:             margin-bottom: 20px;\n141:         }\n142: \n143:         .hero h1 {\n144:             font-family: 'Orbitron', sans-serif;\n145:             font-size: clamp(1.8rem, 6vw, 3rem);\n146:             font-weight: 900;\n147:             color: #fff;\n148:             text-transform: uppercase;\n149:             letter-spacing: 3px;\n150:             animation: neonPulse 3s ease-in-out infinite, flicker 4s infinite;\n151:             position: relative;\n152:         }\n153: \n154:         .hero h1::after {\n155:             content: attr(data-text);\n156:             position: absolute;\n157:             left: 2px;\n158:             top: 0;\n159:             color: var(--magenta);\n160:             opacity: 0;\n161:             clip-path: inset(0 0 0 0);\n162:             animation: glitchClip 5s infinite;\n163:         }\n164: \n165:         @keyframes glitchClip {\n166:             0%, 90%, 100% { clip-path: inset(0 100% 0 0); opacity: 0; }\n167:             92% { clip-path: inset(20% 0 60% 0); opacity: 0.7; transform: translate(-3px, 1px); }\n168:             94% { clip-path: inset(60% 0 10% 0); opacity: 0.7; transform: translate(3px, -1px); }\n169:             96% { clip-path: inset(40% 0 30% 0); opacity: 0.7; transform: translate(-2px, 0); }\n170:         }\n171: \n172:         .hero .tagline {\n173:             font-family: 'Share Tech Mono', monospace;\n174:             font-size: 0.85rem;\n175:             color: rgba(0, 240, 255, 0.5);\n176:             margin-top: 12px;\n177:             letter-spacing: 2px;\n178:         }\n179: \n180:         .info-grid {\n181:             display: grid;\n182:             grid-template-columns: repeat(2, 1fr);\n183:             gap: 12px;\n184:             margin-bottom: 24px;\n185:         }\n186: \n187:         .info-card {\n188:             background: var(--panel);\n189:             border: 1px solid rgba(176, 0, 255, 0.2);\n190:             border-radius: 10px;\n191:             padding: 16px 12px;\n192:             text-align: center;\n193:             backdrop-filter: blur(10px);\n194:             transition: all 0.3s;\n195:             animation: borderPulse 4s ease-in-out infinite;\n196:         }\n197: \n198:         .info-card:nth-child(2) { animation-delay: 0.5s; }\n199:         .info-card:nth-child(3) { animation-delay: 1s; }\n200:         .info-card:nth-child(4) { animation-delay: 1.5s; }\n201: \n202:       