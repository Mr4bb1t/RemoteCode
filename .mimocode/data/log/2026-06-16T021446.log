 flex;\n318:             align-items: center;\n319:             justify-content: center;\n320:             font-size: 1.1rem;\n321:             flex-shrink: 0;\n322:             border: 1px solid rgba(0, 240, 255, 0.2);\n323:         }\n324: \n325:         .file-details { min-width: 0; }\n326: \n327:         .file-name {\n328:             font-family: 'Share Tech Mono', monospace;\n329:             font-size: 0.8rem;\n330:             color: #e0e0e8;\n331:             white-space: nowrap;\n332:             overflow: hidden;\n333:             text-overflow: ellipsis;\n334:         }\n335: \n336:         .file-meta {\n337:             font-size: 0.65rem;\n338:             color: rgba(0, 240, 255, 0.4);\n339:             margin-top: 2px;\n340:             font-family: 'Share Tech Mono', monospace;\n341:         }\n342: \n343:         .download-btn {\n344:             background: linear-gradient(135deg, var(--cyan), var(--purple));\n345:             color: #000;\n346:             border: none;\n347:             padding: 8px 18px;\n348:             border-radius: 6px;\n349:             cursor: pointer;\n350:             text-decoration: none;\n351:             font-family: 'Orbitron', sans-serif;\n352:             font-size: 0.65rem;\n353:             font-weight: 700;\n354:             letter-spacing: 1px;\n355:             text-transform: uppercase;\n356:             transition: all 0.3s;\n357:             flex-shrink: 0;\n358:             margin-left: 12px;\n359:         }\n360: \n361:         .download-btn:hover {\n362:             box-shadow: 0 0 20px rgba(0, 240, 255, 0.5), 0 0 40px rgba(176, 0, 255, 0.3);\n363:             transform: scale(1.05);\n364:         }\n365: \n366:         .download-btn:active {\n367:             transform: scale(0.97);\n368:         }\n369: \n370:         .empty-state {\n371:             text-align: center;\n372:             padding: 40px 20px;\n373:         }\n374: \n375:         .empty-state .empty-icon {\n376:             font-size: 